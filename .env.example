# Copy this file to `.env` before running the demo.

# Absolute or relative path to the required OpenClaw checkout.
# Example:
# git clone https://github.com/sakuralaa/openclaw.git openclaw
# OPENCLAW_REPO_PATH=../openclaw
# OPENCLAW_REPO_PATH=/Users/your-name/src/openclaw
OPENCLAW_REPO_PATH=../openclaw

# Host port for the demo's Dockerized OpenClaw gateway.
OPENCLAW_GATEWAY_PORT=18799

# Base URL used by scripts/openclaw_demo_agent.py.
OPENCLAW_BASE_URL=http://127.0.0.1:18799

# Required gateway token for this demo gateway.
OPENCLAW_GATEWAY_TOKEN=replace-me

# Required for the Dockerized OpenClaw gateway to talk to Gemini.
GEMINI_API_KEY=replace-me

# Primary provider/model configured inside the demo gateway.
# Change this and restart Docker if you want OpenClaw to use another upstream model.
OPENCLAW_PRIMARY_MODEL=google/gemini-3-flash-preview

# Usually "main".
OPENCLAW_AGENT_ID=main

# Model field sent to /v1/chat/completions. `openclaw` means "use the agent default".
OPENCLAW_MODEL=openclaw

# Increase this for fix mode if the agent edits many files.
OPENCLAW_TIMEOUT_SECONDS=180

# Optional: how long docker_up.sh waits for the gateway socket to accept connections.
OPENCLAW_STARTUP_TIMEOUT_SECONDS=30
